---
/**
 * Breadcrumb.astro — Layout chrome (couche 4).
 *
 * Rôle : fil d'Ariane sémantique ET JSON-LD `BreadcrumbList`.
 *
 * Identité « Baie des Anges » : items séparés par `/` couleur
 * `--color-border`, page courante en ink medium.
 *
 * Rendu dans : ServiceLayout, ZoneLayout, ContentLayout + toutes les
 * pages internes sous le Header.
 */

import { site } from '@/data/site';

export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const itemListElement = items.map((item, index) => ({
  '@type': 'ListItem',
  position: index + 1,
  name: item.label,
  ...(item.href ? { item: new URL(item.href, site.url).toString() } : {}),
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement,
};
---

<nav class="breadcrumb" aria-label="Fil d'Ariane">
  <ol class="breadcrumb__list" role="list">
    {items.map((item, index) => {
      const isLast = index === items.length - 1;
      return (
        <li class="breadcrumb__item">
          {item.href && !isLast ? (
            <a class="breadcrumb__link" href={item.href}>{item.label}</a>
          ) : (
            <span class="breadcrumb__current" aria-current="page">{item.label}</span>
          )}
          {!isLast && <span class="breadcrumb__sep" aria-hidden="true">/</span>}
        </li>
      );
    })}
  </ol>
</nav>

<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<style>
  .breadcrumb {
    padding-block: var(--space-4);
    font-size: 0.8125rem; /* 13px */
    color: var(--color-text-muted);
  }
  .breadcrumb__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    line-height: 1;
  }
  .breadcrumb__item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }
  .breadcrumb__link {
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .breadcrumb__link:hover {
    color: var(--color-azur);
  }
  .breadcrumb__current {
    color: var(--color-text);
    font-weight: var(--font-weight-medium);
  }
  .breadcrumb__sep {
    color: var(--color-border);
  }
</style>
