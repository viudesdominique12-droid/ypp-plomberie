---
/**
 * Footer.astro — Layout chrome (couche 4).
 *
 * Direction "Éditorial Architecture" :
 *   - Fond charbon profond.
 *   - Wordmark "Ypp." en haut + tagline.
 *   - 4 colonnes desktop / pile mobile : Marque · Services · Zones · Contact.
 *   - Tout en typo sobre : mono pour les titres de colonne, Inter pour
 *     les listes, Fraunces uniquement pour le wordmark.
 */

import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import Icon from '@/components/ui/Icon.astro';
import { nap, site, labels } from '@/data/site';
import { url } from '@/utils/url';
import { getCollection } from 'astro:content';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order,
);
const zones = (await getCollection('zones')).sort((a, b) =>
  a.data.commune.localeCompare(b.data.commune, 'fr'),
);

const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <Container width="wide" as="div">
    <div class="site-footer__grid">
      <section class="site-footer__brand-col" aria-label="À propos">
        <a class="site-footer__brand" href={url('/')} aria-label={`Accueil — ${site.name}`}>
          <span class="site-footer__wordmark">Ypp<span class="site-footer__dot">.</span></span>
          <span class="site-footer__tag">Plomberie · Nice</span>
        </a>
        <p class="site-footer__tagline">
          Artisan plombier à Nice — dépannage {labels.open247}, rénovation
          de salle de bain, recherche de fuite et chauffage. Assurance décennale.
        </p>
        <div class="site-footer__cta">
          <Button
            href={`tel:${nap.phoneE164}`}
            variant="urgence"
            size="sm"
            ariaLabel={`${labels.callNow} — ${nap.phoneDisplay}`}
          >
            <Icon slot="icon-leading" name="phone" size={14} />
            {nap.phoneDisplay}
          </Button>
        </div>
      </section>

      <nav class="site-footer__col" aria-label="Services">
        <p class="site-footer__col-title">Services</p>
        <ul role="list" class="site-footer__list">
          {services.map((s) => (
            <li>
              <a href={url(`/services/${s.data.slug}/`)}>{s.data.title}</a>
            </li>
          ))}
        </ul>
      </nav>

      <nav class="site-footer__col" aria-label="Zones desservies">
        <p class="site-footer__col-title">Zones</p>
        <ul role="list" class="site-footer__list">
          <li><a href={url('/')}>Nice & alentours</a></li>
          {zones.map((z) => (
            <li>
              <a href={url(`/zones/${z.data.slug}/`)}>{z.data.commune}</a>
            </li>
          ))}
        </ul>
      </nav>

      <section class="site-footer__col" aria-label="Contact">
        <p class="site-footer__col-title">Contact</p>
        <ul role="list" class="site-footer__list site-footer__list--plain">
          <li>{nap.phoneDisplay}</li>
          <li>{nap.email}</li>
          <li>{nap.address.city} ({nap.address.postalCode})</li>
        </ul>
        <div class="site-footer__legal">
          <a href={url('/mentions-legales/')}>Mentions légales</a>
          <span aria-hidden="true">·</span>
          <a href={url('/politique-de-confidentialite/')}>Confidentialité</a>
        </div>
      </section>
    </div>

    <div class="site-footer__bottom">
      <p>© {year} {site.legalName} — Tous droits réservés</p>
      <p>SIRET {nap.identifiers.siret} · Assurance décennale</p>
    </div>
  </Container>
</footer>

<style>
  .site-footer {
    background: var(--color-surface-dark);
    color: var(--color-on-dark);
    margin-top: 0;
    position: relative;
  }
  .site-footer :global(.container) {
    padding-block: 0;
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    padding-block: clamp(3rem, 5vw, 5rem);
    border-bottom: 1px solid rgba(238, 243, 246, 0.08);
  }
  @media (min-width: 768px) {
    .site-footer__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 48px;
    }
  }
  @media (min-width: 1024px) {
    .site-footer__grid {
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
      gap: 64px;
    }
  }

  .site-footer__brand {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    text-decoration: none;
    color: var(--color-on-dark);
  }
  .site-footer__wordmark {
    font-family: var(--font-family-display);
    font-weight: var(--font-weight-bold);
    font-size: 1.75rem;
    letter-spacing: -0.04em;
    line-height: 1;
  }
  .site-footer__dot { color: var(--color-terra); }
  .site-footer__tag {
    font-family: var(--font-family-mono);
    font-size: 0.65rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(238, 243, 246, 0.55);
  }
  .site-footer__tagline {
    margin: 22px 0 0;
    color: rgba(238, 243, 246, 0.65);
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: 360px;
  }
  .site-footer__cta { margin-top: 24px; }

  .site-footer__col-title {
    margin: 0 0 22px 0;
    font-family: var(--font-family-mono);
    font-size: 0.7rem;
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(238, 243, 246, 0.55);
  }
  .site-footer__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .site-footer__list a {
    color: rgba(238, 243, 246, 0.78);
    font-size: 0.9375rem;
    text-decoration: none;
    transition: color var(--transition-fast) var(--ease-out);
  }
  .site-footer__list a:hover { color: var(--color-terra); }
  .site-footer__list--plain {
    color: rgba(238, 243, 246, 0.78);
    font-size: 0.9375rem;
    line-height: 1.6;
  }
  .site-footer__legal {
    margin-top: 22px;
    font-family: var(--font-family-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .site-footer__legal a {
    color: rgba(238, 243, 246, 0.7);
    text-decoration: none;
  }
  .site-footer__legal a:hover { color: var(--color-terra); }
  .site-footer__legal span {
    color: rgba(238, 243, 246, 0.3);
    margin: 0 10px;
  }

  .site-footer__bottom {
    padding-block: 24px;
    font-family: var(--font-family-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(238, 243, 246, 0.45);
    display: flex;
    flex-direction: column;
    gap: 8px;
    justify-content: space-between;
    align-items: flex-start;
  }
  @media (min-width: 768px) {
    .site-footer__bottom {
      flex-direction: row;
      align-items: center;
    }
  }
  .site-footer__bottom p { margin: 0; }
</style>
