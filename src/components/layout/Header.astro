---
/**
 * Header.astro — Layout chrome (couche 4).
 *
 * Rôle : barre de navigation principale du site.
 *
 * Identité « Baie des Anges » :
 *   - Sticky, fond blanc 92 % + backdrop-blur, bordure bas soft.
 *   - Desktop : grille 3 colonnes — logo (gauche) | nav centrée |
 *     CTAs (droite) : "Devis gratuit" secondary-sm + tel urgence-sm.
 *   - Mobile : logo | "Devis" sm | bouton icône urgence | burger.
 *
 * Rendu dans : src/layouts/BaseLayout.astro.
 * Données lues : src/data/site.ts (nav, nap, labels).
 */

import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import Icon from '@/components/ui/Icon.astro';
import WaterDropLogo from '@/components/ui/WaterDropLogo.astro';
import { primaryNav, nap, labels, site } from '@/data/site';

const currentPath = Astro.url.pathname;

function isCurrent(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href);
}
---

<header class="site-header" role="banner">
  <Container width="wide" as="div" class="site-header__inner">
    <a class="site-header__brand" href="/" aria-label={`Accueil — ${site.name}`}>
      <WaterDropLogo variant="azur" />
      <span class="site-header__name">
        <span class="site-header__title">{site.name}</span>
        <span class="site-header__sub">Nice · Baie des Anges</span>
      </span>
    </a>

    {/* Desktop nav */}
    <nav class="site-header__nav-desk" aria-label="Navigation principale">
      <ul class="site-header__nav-list" role="list">
        {primaryNav.filter((n) => n.href !== '/').map((item) => (
          <li>
            <a
              href={item.href}
              class={`site-header__nav-link${isCurrent(item.href) ? ' is-current' : ''}`}
              aria-current={isCurrent(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    {/* CTAs desktop */}
    <div class="site-header__cta-desk">
      <Button href="/contact/" variant="secondary" size="sm">
        {labels.requestQuote}
      </Button>
      <Button
        href={`tel:${nap.phoneE164}`}
        variant="urgence"
        size="sm"
        ariaLabel={`${labels.callNow} — ${nap.phoneDisplay}`}
      >
        <Icon slot="icon-leading" name="phone" size={14} />
        {nap.phoneDisplay}
      </Button>
    </div>

    {/* Mobile actions */}
    <div class="site-header__cta-mob">
      <Button href="/contact/" variant="secondary" size="sm">Devis</Button>
      <Button
        href={`tel:${nap.phoneE164}`}
        variant="urgence"
        size="sm"
        ariaLabel={`${labels.callNow} — ${nap.phoneDisplay}`}
      >
        <Icon name="phone" size={14} />
      </Button>
      <details class="site-header__menu">
        <summary class="site-header__burger" aria-label="Ouvrir le menu">
          <Icon name="menu" size={20} />
          <span class="visually-hidden">Menu</span>
        </summary>
        <nav class="site-header__panel" aria-label="Navigation mobile">
          <ul role="list">
            {primaryNav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class={`site-header__panel-link${isCurrent(item.href) ? ' is-current' : ''}`}
                  aria-current={isCurrent(item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
                {item.children && (
                  <ul role="list" class="site-header__panel-sub">
                    {item.children.map((c) => (
                      <li>
                        <a
                          href={c.href}
                          class={`site-header__panel-sublink${isCurrent(c.href) ? ' is-current' : ''}`}
                          aria-current={isCurrent(c.href) ? 'page' : undefined}
                        >
                          {c.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </nav>
      </details>
    </div>
  </Container>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border-soft);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: 12px;
  }

  /* === Brand === */
  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }
  .site-header__name { display: flex; flex-direction: column; line-height: 1; }
  .site-header__title {
    font-family: var(--font-family-heading);
    font-weight: var(--font-weight-semibold);
    font-size: 1.1875rem; /* 19px */
    letter-spacing: -0.012em;
    color: var(--color-text);
  }
  .site-header__sub {
    margin-top: 3px;
    font-size: 0.65rem; /* ~10.5px */
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* === Desktop nav === */
  .site-header__nav-desk { display: none; }
  .site-header__cta-desk { display: none; }

  @media (min-width: 1024px) {
    .site-header__inner {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: var(--space-8);
    }
    .site-header__nav-desk { display: block; }
    .site-header__cta-desk {
      display: flex;
      gap: var(--space-2);
      justify-content: flex-end;
    }
    .site-header__cta-mob { display: none; }
  }

  .site-header__nav-list {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .site-header__nav-link {
    padding: 8px 14px;
    font-size: 0.9rem;
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition:
      background-color var(--transition-fast) var(--ease-out),
      color var(--transition-fast) var(--ease-out);
  }
  .site-header__nav-link:hover {
    background: var(--color-azur-light);
    color: var(--color-azur);
  }
  .site-header__nav-link.is-current {
    background: var(--color-azur-light);
    color: var(--color-azur);
  }

  /* === Mobile actions === */
  .site-header__cta-mob {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .site-header__menu {
    position: relative;
  }
  .site-header__burger {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    list-style: none;
    cursor: pointer;
  }
  .site-header__burger::-webkit-details-marker { display: none; }
  .site-header__panel {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 240px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    padding: var(--space-2);
    z-index: var(--z-overlay);
  }
  .site-header__panel ul { display: flex; flex-direction: column; gap: 4px; }
  .site-header__panel-link,
  .site-header__panel-sublink {
    display: block;
    padding: 10px 12px;
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.9375rem;
    font-weight: var(--font-weight-medium);
  }
  .site-header__panel-sublink {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    padding: 6px 12px;
  }
  .site-header__panel-link:hover,
  .site-header__panel-sublink:hover {
    background: var(--color-surface-alt);
    color: var(--color-azur);
  }
  .site-header__panel-link.is-current,
  .site-header__panel-sublink.is-current {
    color: var(--color-azur);
    font-weight: var(--font-weight-semibold);
  }
  .site-header__panel-sub {
    padding-left: 14px;
    border-left: 2px solid var(--color-border-soft);
    margin: 2px 0 6px 14px;
  }
</style>
