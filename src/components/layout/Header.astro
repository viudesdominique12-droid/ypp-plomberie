---
/**
 * Header.astro — Layout chrome (couche 4).
 *
 * Registre "Éditorial Architecture" :
 *   - Fond crème pierre (transparent au-dessus du hero, opaque ailleurs).
 *   - Wordmark "Ypp." Fraunces 700 ferme + petit caractère mono "Plomberie · Nice".
 *   - Nav inline en mono uppercase, mini-tracking, séparée par fines barres.
 *   - CTAs : "Devis" texte ghost + "Appeler" terracotta plein.
 *
 * Rendu dans : src/layouts/BaseLayout.astro.
 * Données lues : src/data/site.ts.
 */

import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import Icon from '@/components/ui/Icon.astro';
import { primaryNav, nap, labels, site } from '@/data/site';

const currentPath = Astro.url.pathname;

function isCurrent(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href);
}
---

<header class="site-header" role="banner">
  <Container width="wide" as="div" class="site-header__inner">
    <a class="site-header__brand" href="/" aria-label={`Accueil — ${site.name}`}>
      <span class="site-header__wordmark">Ypp<span class="site-header__dot">.</span></span>
      <span class="site-header__tag">Plomberie · Nice</span>
    </a>

    {/* Desktop nav */}
    <nav class="site-header__nav-desk" aria-label="Navigation principale">
      <ul class="site-header__nav-list" role="list">
        {primaryNav.filter((n) => n.href !== '/').map((item) => (
          <li>
            <a
              href={item.href}
              class={`site-header__nav-link${isCurrent(item.href) ? ' is-current' : ''}`}
              aria-current={isCurrent(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    {/* CTAs desktop */}
    <div class="site-header__cta-desk">
      <a href="/contact/" class="site-header__quote">Devis sous 24 h</a>
      <Button
        href={`tel:${nap.phoneE164}`}
        variant="urgence"
        size="sm"
        ariaLabel={`${labels.callNow} — ${nap.phoneDisplay}`}
      >
        <Icon slot="icon-leading" name="phone" size={14} />
        {nap.phoneDisplay}
      </Button>
    </div>

    {/* Mobile actions */}
    <div class="site-header__cta-mob">
      <Button
        href={`tel:${nap.phoneE164}`}
        variant="urgence"
        size="sm"
        ariaLabel={`${labels.callNow} — ${nap.phoneDisplay}`}
      >
        <Icon name="phone" size={14} />
      </Button>
      <details class="site-header__menu">
        <summary class="site-header__burger" aria-label="Ouvrir le menu">
          <Icon name="menu" size={20} />
          <span class="visually-hidden">Menu</span>
        </summary>
        <nav class="site-header__panel" aria-label="Navigation mobile">
          <ul role="list">
            {primaryNav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class={`site-header__panel-link${isCurrent(item.href) ? ' is-current' : ''}`}
                  aria-current={isCurrent(item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
                {item.children && (
                  <ul role="list" class="site-header__panel-sub">
                    {item.children.map((c) => (
                      <li>
                        <a
                          href={c.href}
                          class={`site-header__panel-sublink${isCurrent(c.href) ? ' is-current' : ''}`}
                          aria-current={isCurrent(c.href) ? 'page' : undefined}
                        >
                          {c.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </nav>
      </details>
    </div>
  </Container>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: rgba(244, 241, 235, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border-soft);
  }
  /* En desktop, le SideNav prend le relais. Le header reste pour mobile. */
  @media (min-width: 1024px) {
    .site-header { display: none; }
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: 18px;
  }

  /* === Brand wordmark === */
  .site-header__brand {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }
  .site-header__wordmark {
    font-family: var(--font-family-display);
    font-weight: var(--font-weight-bold);
    font-size: 1.5rem;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-text);
  }
  .site-header__dot {
    color: var(--color-terra);
  }
  .site-header__tag {
    font-family: var(--font-family-mono);
    font-size: 0.65rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-soft);
    display: none;
  }
  @media (min-width: 640px) {
    .site-header__tag { display: inline; }
  }

  /* === Desktop nav (cachés par défaut, révélés en >=1024px) === */
  .site-header__nav-desk { display: none; }
  .site-header__cta-desk { display: none; }

  /* === Mobile actions (visibles par défaut, cachées en >=1024px) === */
  .site-header__cta-mob {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  @media (min-width: 1024px) {
    .site-header__inner {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: var(--space-8);
    }
    .site-header__nav-desk { display: block; }
    .site-header__cta-desk {
      display: flex;
      gap: var(--space-5);
      align-items: center;
      justify-content: flex-end;
    }
    .site-header__cta-mob { display: none; }
  }

  .site-header__nav-list {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .site-header__nav-link {
    position: relative;
    padding: 4px 0;
    font-family: var(--font-family-mono);
    font-size: 0.7rem;
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition-fast) var(--ease-out);
  }
  .site-header__nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: var(--color-text);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition-base) var(--ease-out);
  }
  .site-header__nav-link:hover { color: var(--color-text); }
  .site-header__nav-link:hover::after,
  .site-header__nav-link.is-current::after {
    transform: scaleX(1);
  }
  .site-header__nav-link.is-current {
    color: var(--color-text);
  }

  /* Lien "Devis sous 24 h" — pas un bouton, lien éditorial souligné. */
  .site-header__quote {
    font-family: var(--font-family-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-text);
    padding-bottom: 4px;
    transition: color var(--transition-fast) var(--ease-out);
  }
  .site-header__quote:hover {
    color: var(--color-terra);
    border-color: var(--color-terra);
  }

  /* === Mobile menu panel === */
  .site-header__menu { position: relative; }
  .site-header__burger {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-strong);
    background: transparent;
    color: var(--color-text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    list-style: none;
    cursor: pointer;
  }
  .site-header__burger::-webkit-details-marker { display: none; }
  .site-header__panel {
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    min-width: 260px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    padding: var(--space-3);
    z-index: var(--z-overlay);
  }
  .site-header__panel ul { display: flex; flex-direction: column; gap: 2px; }
  .site-header__panel-link,
  .site-header__panel-sublink {
    display: block;
    padding: 10px 12px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--color-text);
    font-family: var(--font-family-base);
    font-size: 0.95rem;
    font-weight: var(--font-weight-medium);
  }
  .site-header__panel-sublink {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    padding: 6px 12px;
  }
  .site-header__panel-link:hover,
  .site-header__panel-sublink:hover {
    background: var(--color-surface-alt);
  }
  .site-header__panel-link.is-current,
  .site-header__panel-sublink.is-current {
    color: var(--color-terra);
    font-weight: var(--font-weight-semibold);
  }
  .site-header__panel-sub {
    padding-left: 14px;
    border-left: 1px solid var(--color-border-soft);
    margin: 4px 0 8px 14px;
  }
</style>
