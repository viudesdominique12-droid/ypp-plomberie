---
/**
 * StickyCallBar.astro — Layout chrome (couche 4).
 *
 * Rôle : barre d'action mobile fixée en bas. Urgence (flex 1.3) +
 * secondary "Devis" (flex 1). Fond blanc 96 % + blur, respect du
 * safe-area-inset-bottom (iOS notch).
 *
 * Rendu dans : BaseLayout, partout SAUF page légale.
 * Masquée en tablette/desktop (≥ 768px).
 */

import Icon from '@/components/ui/Icon.astro';
import { nap, labels } from '@/data/site';
import { url } from '@/utils/url';
---

<div class="sticky-call-bar" role="region" aria-label="Actions rapides">
  <a
    class="sticky-call-bar__btn sticky-call-bar__btn--call"
    href={`tel:${nap.phoneE164}`}
    aria-label={`${labels.callNow} — ${nap.phoneDisplay}`}
  >
    <Icon name="phone" size={16} />
    <span>{nap.phoneDisplay}</span>
  </a>
  <a
    class="sticky-call-bar__btn sticky-call-bar__btn--quote"
    href={url('/contact/')}
  >
    <span>Devis</span>
  </a>
</div>

<style>
  .sticky-call-bar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: var(--z-sticky);
    display: flex;
    gap: 8px;
    padding: 10px 14px calc(14px + env(safe-area-inset-bottom));
    background: rgba(238, 243, 246, 0.96);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-top: 1px solid var(--color-border);
  }
  @media (min-width: 768px) {
    .sticky-call-bar { display: none; }
  }

  .sticky-call-bar__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    min-height: 46px;
    font-weight: var(--font-weight-semibold);
    font-size: 0.875rem;
    text-decoration: none;
    border: 1.5px solid transparent;
  }
  .sticky-call-bar__btn--call {
    flex: 1.3;
    background: var(--color-terra);
    color: var(--color-on-urgent);
    border-color: var(--color-terra);
  }
  .sticky-call-bar__btn--quote {
    flex: 1;
    background: transparent;
    color: var(--color-text);
    border-color: var(--color-text);
  }
</style>
