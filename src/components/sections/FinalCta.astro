---
/**
 * FinalCta.astro — Section.
 *
 * Bloc de conversion final, pleine largeur (charbon).
 * Le CtaBlock gère lui-même son fond et son padding.
 */

import CtaBlock from '@/components/ui/CtaBlock.astro';

export interface Props {
  title?: string;
  lead?: string;
}

const { title, lead } = Astro.props;
---

<section id="FinalCta">
  <CtaBlock title={title} lead={lead} />
</section>
