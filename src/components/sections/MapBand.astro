---
/**
 * MapBand.astro — Section.
 *
 * Rôle : bande pleine largeur, hauteur fixe, fond `placeholder.map`
 * avec label centré. À remplacer par un embed Google Maps en phase 3.
 *
 * Rendu dans : src/pages/contact/index.astro.
 */

export interface Props {
  label?: string;
}

const { label = 'Carte — Nice & baie des Anges' } = Astro.props;
---

<section id="MapBand" class="map-band" aria-label={label}>
  <span class="map-band__label">{label}</span>
</section>

<style>
  .map-band {
    position: relative;
    background:
      radial-gradient(60% 80% at 30% 60%, rgba(14,100,128,.18), transparent 60%),
      radial-gradient(40% 50% at 80% 20%, rgba(201,119,47,.10), transparent 60%),
      linear-gradient(160deg, #eef3f4 0%, #dde8eb 100%);
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  @media (min-width: 768px) {
    .map-band { height: 320px; }
  }
  .map-band__label {
    font-size: 0.6875rem;
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(14, 100, 128, 0.55);
  }
</style>
