---
/**
 * ReviewsSection.astro — Section.
 *
 * Direction "Éditorial Architecture" :
 *   - Titre Fraunces + meta mono.
 *   - Avis présentés en grand "Q —" italique Fraunces, citation
 *     manuscrite, signature à droite. Pas de cartes avec pastilles.
 */

import Section from '@/components/ui/Section.astro';
import { site } from '@/data/site';

const reviews = [
  {
    quote:
      "Fuite chez nous un dimanche soir. Arrivé en quarante minutes, diagnostic clair, tarif annoncé avant d'intervenir. Du travail propre.",
    author: 'Camille R.',
    place: 'Nice — Cimiez',
  },
  {
    quote:
      "Rénovation complète de la salle de bain en deux semaines. Pas un jour de retard, finitions impeccables. Je le recommande les yeux fermés.",
    author: 'Antoine D.',
    place: 'Villefranche-sur-Mer',
  },
  {
    quote:
      "Chaudière capricieuse depuis trois hivers, deux artisans avant lui n'avaient rien trouvé. Réparée en une intervention. Bravo.",
    author: 'Hélène M.',
    place: 'Cagnes-sur-Mer',
  },
];
---

<Section id="ReviewsSection" surface="default" spacing="lg" width="wide">
  <header class="reviews-section__head">
    <p class="reviews-section__eyebrow" data-anim="rise">
      <span>05</span>
      <span class="reviews-section__rule"></span>
      <span>Témoignages</span>
    </p>
    <h2 class="reviews-section__title" data-anim="rise">
      <em><span data-anim="counter" data-target={site.rating.value} data-decimals="1">{site.rating.value.toFixed(1).replace('.', ',')}</span> / 5</em> sur Google,
      <br />et ce qu'on en dit.
    </h2>
    <p class="reviews-section__meta" data-anim="rise">
      {site.rating.count} avis certifiés · Source : Google Business
    </p>
  </header>

  <ul class="reviews-section__list" role="list">
    {reviews.map((review, i) => (
      <li class="reviews-section__item" data-anim="rise">
        <span class="reviews-section__quote-mark" aria-hidden="true">“</span>
        <blockquote class="reviews-section__quote">
          {review.quote}
        </blockquote>
        <footer class="reviews-section__sign">
          <span class="reviews-section__num">N°{String(i + 1).padStart(2, '0')}</span>
          <span class="reviews-section__author">{review.author}</span>
          <span class="reviews-section__place">{review.place}</span>
        </footer>
      </li>
    ))}
  </ul>
</Section>

<style>
  .reviews-section__head {
    margin-bottom: clamp(3rem, 6vw, 5rem);
    max-width: 920px;
  }
  .reviews-section__eyebrow {
    margin: 0 0 clamp(1.5rem, 3vw, 2rem);
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
    font-family: var(--font-family-mono);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-soft);
  }
  .reviews-section__rule {
    display: inline-block;
    width: 48px;
    height: 1px;
    background: var(--color-text-soft);
  }
  .reviews-section__title {
    margin: 0;
    font-family: var(--font-family-display);
    font-weight: var(--font-weight-medium);
    font-size: clamp(2rem, 5vw, 3.75rem);
    line-height: 1.02;
    letter-spacing: var(--letter-spacing-tighter);
    color: var(--color-text);
  }
  .reviews-section__title em {
    font-family: var(--font-family-mono);
    font-style: normal;
    color: var(--color-terra);
    font-weight: var(--font-weight-regular);
  }
  .reviews-section__meta {
    margin: var(--space-5) 0 0;
    font-family: var(--font-family-mono);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-soft);
  }

  .reviews-section__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid var(--color-border);
  }
  @media (min-width: 900px) {
    .reviews-section__list {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .reviews-section__item {
    position: relative;
    padding: clamp(2.5rem, 4vw, 3.5rem) 0 clamp(2.5rem, 4vw, 3.5rem);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  @media (min-width: 900px) {
    .reviews-section__item {
      padding-inline: clamp(1.5rem, 2.5vw, 2.5rem);
      border-bottom: 0;
      border-right: 1px solid var(--color-border);
      padding-block: 0;
      min-height: 360px;
    }
    .reviews-section__item:first-child { padding-left: 0; }
    .reviews-section__item:last-child {
      border-right: 0;
      padding-right: 0;
    }
  }

  .reviews-section__quote-mark {
    font-family: var(--font-family-display);
    font-style: italic;
    font-size: 4.5rem;
    line-height: 1;
    color: var(--color-terra);
  }

  .reviews-section__quote {
    margin: 0;
    font-family: var(--font-family-display);
    font-style: italic;
    font-weight: var(--font-weight-regular);
    font-size: clamp(1.0625rem, 1.4vw, 1.25rem);
    line-height: 1.45;
    color: var(--color-text);
    flex: 1;
  }

  .reviews-section__sign {
    display: grid;
    gap: 4px;
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border-soft);
  }
  .reviews-section__num {
    font-family: var(--font-family-mono);
    font-size: 0.65rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-terra);
  }
  .reviews-section__author {
    font-family: var(--font-family-base);
    font-weight: var(--font-weight-semibold);
    font-size: 0.95rem;
    color: var(--color-text);
  }
  .reviews-section__place {
    font-family: var(--font-family-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-soft);
  }
</style>
