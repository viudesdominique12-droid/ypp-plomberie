---
/**
 * ServicesGrid.astro — Section.
 *
 * Rôle : grille des services proposés. Lit la collection `services`,
 * ordonne par `order`. Identité « Baie des Anges » respectée via
 * `ServiceCard`.
 *
 * Rendu dans : src/pages/index.astro,
 *              src/pages/services/index.astro,
 *              src/layouts/ZoneLayout.astro,
 *              src/pages/zones/[slug].astro.
 *
 * NB : ne JAMAIS coder en dur la liste des services ici. Ajouter
 *      un service = créer un `.md` dans `src/content/services/`.
 */

import Section from '@/components/ui/Section.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import ServiceCard from '@/components/ui/ServiceCard.astro';
import { getCollection } from 'astro:content';

export interface Props {
  eyebrow?: string;
  title?: string;
  lead?: string;
  /** ID du service à exclure (ex. on n'affiche pas le service courant). */
  excludeId?: string;
  /** Surface du bloc (par défaut surface blanche). */
  surface?: 'default' | 'alt' | 'bg';
  /** Nombre de colonnes max à partir de 1024px. */
  columns?: 2 | 3;
  /** Limite le nombre d'entrées affichées. */
  limit?: number;
  /** Cacher le bloc de titre (utilisé sur le hub services). */
  hideHeading?: boolean;
}

const {
  eyebrow = 'Nos services',
  title = 'Une expertise complète, un seul interlocuteur',
  lead = "Du dépannage urgent à la rénovation complète, six métiers maîtrisés par un seul artisan.",
  excludeId,
  surface = 'default',
  columns = 3,
  limit,
  hideHeading = false,
} = Astro.props;

const all = (await getCollection('services'))
  .filter((entry) => entry.id !== excludeId)
  .sort((a, b) => a.data.order - b.data.order);

const services = typeof limit === 'number' ? all.slice(0, limit) : all;
---

<Section id="ServicesGrid" surface={surface} spacing="lg" width="wide">
  {!hideHeading && (
    <SectionHeading eyebrow={eyebrow} title={title} lead={lead} />
  )}
  <ul class={`services-grid services-grid--cols-${columns}`} role="list">
    {services.map((entry) => (
      <li>
        <ServiceCard
          href={`/services/${entry.data.slug}/`}
          title={entry.data.title}
          description={entry.data.shortDescription}
          icon={entry.data.icon}
        />
      </li>
    ))}
  </ul>
</Section>

<style>
  .services-grid {
    display: grid;
    gap: var(--space-4);
  }
  @media (min-width: 640px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .services-grid--cols-2 { grid-template-columns: repeat(2, 1fr); gap: var(--space-6); }
    .services-grid--cols-3 { grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  }
</style>
