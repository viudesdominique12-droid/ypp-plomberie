---
/**
 * ZonesSection.astro — Section.
 *
 * Rôle : « De Nice à la Riviera. » Carte placeholder + grille de
 * 12 tags-pill ville (variante `tile` du ZoneCard).
 *
 * Rendu dans : src/pages/index.astro et toute page qui rappelle la
 * zone d'intervention. La page /zone-intervention/ utilise un autre
 * composant (HubZoneMap) pour son layout grille map + 12.
 *
 * Sources : src/data/site.ts + collection `zones`. La liste de
 * communes étendue (12) reflète la « baie des Anges » au sens large.
 */

import Section from '@/components/ui/Section.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import ZoneCard from '@/components/ui/ZoneCard.astro';
import Placeholder from '@/components/ui/Placeholder.astro';
import AnimatedGridPattern from '@/components/ui/AnimatedGridPattern.astro';
import { getCollection } from 'astro:content';
import { url } from '@/utils/url';

export interface Props {
  eyebrow?: string;
  title?: string;
  lead?: string;
  surface?: 'default' | 'alt';
}

const {
  eyebrow = "Zone d'intervention",
  title = 'De Nice à la Riviera',
  lead = "Une connaissance fine du territoire, des résidences anciennes du centre aux villas du Cap-Ferrat.",
  surface = 'alt',
} = Astro.props;

const collectionZones = await getCollection('zones');
const collectionSlugs = new Set(collectionZones.map((z) => z.data.slug));

/* Communes à afficher en tiles. Si la commune existe dans la
   collection (a sa propre page), on lie vers /zones/<slug>/. Sinon,
   on lie vers le hub d'intervention. */
const tiles = [
  { commune: 'Nice', slug: null },
  { commune: 'Cagnes-sur-Mer', slug: 'cagnes-sur-mer' },
  { commune: 'Saint-Laurent-du-Var', slug: 'saint-laurent-du-var' },
  { commune: 'Villefranche-sur-Mer', slug: 'villefranche-sur-mer' },
  { commune: 'Villeneuve-Loubet', slug: null },
  { commune: 'Antibes', slug: null },
  { commune: 'Beaulieu-sur-Mer', slug: null },
  { commune: 'Èze', slug: null },
  { commune: 'Saint-Jean-Cap-Ferrat', slug: null },
  { commune: 'Cap d\'Ail', slug: null },
  { commune: 'La Trinité', slug: null },
  { commune: 'Roquebrune', slug: null },
];

function tileHref(slug: string | null) {
  if (slug && collectionSlugs.has(slug)) return url(`/zones/${slug}/`);
  return url('/zone-intervention/');
}
---

<Section id="ZonesSection" surface={surface} spacing="lg" width="wide" class="zones-section">
  {/* Grille animée en arrière-plan — métaphore de réseau / map. */}
  <div class="zones-section__bg" aria-hidden="true">
    <AnimatedGridPattern
      cellSize={48}
      numSquares={48}
      maxOpacity={0.18}
      color="rgba(14, 100, 128, 0.5)"
      duration={5}
    />
  </div>

  <SectionHeading eyebrow={eyebrow} title={title} lead={lead} />

  <Placeholder
    variant="map"
    class="zones-section__map"
  />

  <ul class="zones-section__tiles" role="list">
    {tiles.map((t) => (
      <li>
        <ZoneCard
          href={tileHref(t.slug)}
          commune={t.commune}
          variant="tile"
        />
      </li>
    ))}
  </ul>
</Section>

<style>
  /* Fond grille animée — absolute, masqué en dégradé bas pour fondre. */
  :global(.zones-section) {
    position: relative;
    isolation: isolate;
  }
  .zones-section__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 0%, transparent 100%);
    mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 0%, transparent 100%);
  }
  :global(.zones-section) > :global(.container) {
    position: relative;
    z-index: 1;
  }

  .zones-section__map {
    height: 240px;
    margin-bottom: var(--space-6);
    position: relative;
    z-index: 1;
  }
  @media (min-width: 768px) {
    .zones-section__map {
      height: 380px;
      margin-bottom: var(--space-9, 36px);
    }
  }
  .zones-section__tiles {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  @media (min-width: 1024px) {
    .zones-section__tiles { grid-template-columns: repeat(4, 1fr); }
  }
</style>
