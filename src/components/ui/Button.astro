---
/**
 * Button.astro — Primitive UI.
 *
 * Rôle : bouton ou lien stylé, registre éditorial (rectangulaire net,
 * pas pill arrondi). Inter 600. Quatre variantes :
 *   - urgence  : fond terracotta, le plus saillant (CTA téléphone)
 *   - primary  : fond charbon, action principale
 *   - secondary: outline charbon, action secondaire
 *   - ghost    : transparent + underline animé, lien éditorial
 *
 * Si `href` fourni → <a>. Sinon → <button>.
 */

export interface Props {
  href?: string;
  variant?: 'urgence' | 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  fullWidth?: boolean;
  type?: 'button' | 'submit' | 'reset';
  ariaLabel?: string;
  rel?: string;
  target?: string;
  disabled?: boolean;
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  fullWidth = false,
  type = 'button',
  ariaLabel,
  rel,
  target,
  disabled = false,
  class: className,
} = Astro.props;

const classes = [
  'btn',
  `btn--${variant}`,
  `btn--${size}`,
  fullWidth ? 'btn--full' : null,
  className,
]
  .filter(Boolean)
  .join(' ');

const isLink = typeof href === 'string' && href.length > 0;
---

{isLink ? (
  <a
    href={href}
    class={classes}
    aria-label={ariaLabel}
    rel={rel}
    target={target}
  >
    <slot name="icon-leading" />
    <span class="btn__label"><slot /></span>
    <slot name="icon-trailing" />
  </a>
) : (
  <button
    type={type}
    class={classes}
    aria-label={ariaLabel}
    disabled={disabled}
  >
    <slot name="icon-leading" />
    <span class="btn__label"><slot /></span>
    <slot name="icon-trailing" />
  </button>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    font-family: var(--font-family-base);
    font-weight: var(--font-weight-semibold);
    line-height: 1;
    letter-spacing: -0.005em;
    text-decoration: none;
    cursor: pointer;
    white-space: nowrap;
    transition:
      background-color var(--transition-fast) var(--ease-out),
      color var(--transition-fast) var(--ease-out),
      border-color var(--transition-fast) var(--ease-out);
  }
  .btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn:active:not(:disabled) { transform: translateY(1px); }

  /* Tailles — généreuses. */
  .btn--sm { padding: 10px 16px; min-height: 38px; font-size: 0.8125rem; }
  .btn--md { padding: 14px 22px; min-height: 50px; font-size: 0.9375rem; }
  .btn--lg { padding: 18px 30px; min-height: 60px; font-size: 1rem; letter-spacing: 0; }

  .btn--full { width: 100%; }

  /* === Urgence : terracotta, le CTA roi. === */
  .btn--urgence {
    background: var(--color-terra);
    color: var(--color-on-urgent);
    border-color: var(--color-terra);
  }
  .btn--urgence:hover:not(:disabled) {
    background: var(--color-terra-hover);
    border-color: var(--color-terra-hover);
  }

  /* === Primary : charbon plein. === */
  .btn--primary {
    background: var(--color-text);
    color: var(--color-on-dark);
    border-color: var(--color-text);
  }
  .btn--primary:hover:not(:disabled) {
    background: var(--color-petrol);
    border-color: var(--color-petrol);
  }

  /* === Secondary : outline charbon. === */
  .btn--secondary {
    background: transparent;
    color: var(--color-text);
    border-color: var(--color-text);
  }
  .btn--secondary:hover:not(:disabled) {
    background: var(--color-text);
    color: var(--color-on-dark);
  }

  /* === Ghost : lien éditorial avec flèche. Pas de fond, underline animé. === */
  .btn--ghost {
    background: transparent;
    color: var(--color-text);
    border-color: transparent;
    padding-inline: 0;
    min-height: 0;
    border-radius: 0;
  }
  .btn--ghost .btn__label {
    border-bottom: 1px solid currentColor;
    padding-bottom: 4px;
    transition: border-color var(--transition-fast) var(--ease-out);
  }
  .btn--ghost:hover:not(:disabled) {
    color: var(--color-terra);
  }

  .btn__label { display: inline-block; }
</style>
