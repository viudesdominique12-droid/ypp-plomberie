---
/**
 * FaqAccordion.astro — Primitive UI.
 *
 * Rôle : liste accessible de questions / réponses (Q en Playfair 20 px).
 * Repose sur `<details>`/`<summary>` natifs — zéro JS.
 *
 * Identité « Baie des Anges » :
 *   - pastille azur-light avec « + » qui rotate à 45° et passe en azur
 *     plein quand ouvert ;
 *   - conteneur radius lg, séparateurs hairline entre items.
 *
 * Rendu dans : FaqSection.
 */

export interface FaqItem {
  question: string;
  answer: string;
}

export interface Props {
  items: FaqItem[];
  defaultOpenFirst?: boolean;
}

const { items, defaultOpenFirst = false } = Astro.props;
---

<div class="faq">
  {items.map((item, index) => (
    <details
      class="faq__item"
      open={defaultOpenFirst && index === 0 ? true : undefined}
    >
      <summary class="faq__summary">
        <span class="faq__question">{item.question}</span>
        <span class="faq__indicator" aria-hidden="true">+</span>
      </summary>
      <div class="faq__answer">
        <p>{item.answer}</p>
      </div>
    </details>
  ))}
</div>

<style>
  .faq {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .faq__item + .faq__item {
    border-top: 1px solid var(--color-border-soft);
  }
  .faq__summary {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    cursor: pointer;
    list-style: none;
  }
  .faq__summary::-webkit-details-marker { display: none; }
  .faq__question {
    flex: 1;
    font-family: var(--font-family-heading);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-lg); /* 20px */
    line-height: 1.3;
    color: var(--color-text);
  }
  .faq__indicator {
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    border-radius: var(--radius-full);
    background: var(--color-azur-light);
    color: var(--color-azur);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    line-height: 1;
    font-weight: 400;
    transition:
      background var(--transition-base) var(--ease-out),
      color var(--transition-base) var(--ease-out),
      transform var(--transition-base) var(--ease-out);
  }
  .faq__item[open] .faq__indicator {
    background: var(--color-azur);
    color: #fff;
    transform: rotate(45deg);
  }
  .faq__answer {
    padding: 0 var(--space-6) var(--space-6);
    color: var(--color-text-muted);
    font-size: 0.96rem; /* ~15.5px */
    line-height: 1.7;
  }
  .faq__answer p { margin: 0; }
</style>
