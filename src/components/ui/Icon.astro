---
/**
 * Icon.astro — Primitive UI (utilitaire).
 *
 * Rôle : rendre une icône SVG inline à partir d'un identifiant
 * symbolique. Iconographie **monochromatique stroke**, jamais
 * colorée, jamais en aplat — fidèle à l'identité Baie des Anges.
 *
 * SOURCE : Lucide Icons (lucide.dev), 24×24, stroke-width par défaut
 * 2 (overridable par prop). Linecap / linejoin round.
 *
 * Iconify a été utilisé pour récupérer les paths officiels — c'est
 * la même bibliothèque que la communauté React/Vue/etc. utilise.
 *
 * Rendu dans : ServiceCard, IconList, Header, Footer, TrustBar,
 *              ContactDetails, sections de réassurance.
 *
 * Astuce de debug : icône inconnue ⇒ on rend un « ? » discret.
 */

export interface Props {
  /** Identifiant d'icône (voir map ci-dessous). */
  name: string;
  /** Taille en pixels (carré). */
  size?: number;
  /** Couleur explicite — par défaut hérite. */
  color?: string;
  /** Description accessible — vide ⇒ icône décorative. */
  ariaLabel?: string;
  /** Épaisseur du trait (1.5 pour les listes denses, 2 par défaut). */
  strokeWidth?: number;
  class?: string;
}

const {
  name,
  size = 24,
  color = 'currentColor',
  ariaLabel,
  strokeWidth = 2,
  class: className,
} = Astro.props;

const decorative = !ariaLabel;
const classes = ['icon', `icon--${name}`, className].filter(Boolean).join(' ');
---

<svg
  class={classes}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={decorative ? 'true' : undefined}
  role={decorative ? undefined : 'img'}
  aria-label={ariaLabel}
>
  {/* ─── Plomberie / eau (icônes de service) ────────────────── */}
  {name === 'droplet' && (
    <path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5S5 13 5 15a7 7 0 0 0 7 7" />
  )}
  {name === 'droplets' && (
    <>
      <path d="M7 16.3c2.2 0 4-1.83 4-4.05c0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05" />
      <path d="M12.56 6.6A11 11 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97" />
    </>
  )}
  {name === 'wrench' && (
    <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.106-3.105c.32-.322.863-.22.983.218a6 6 0 0 1-8.259 7.057l-7.91 7.91a1 1 0 0 1-2.999-3l7.91-7.91a6 6 0 0 1 7.057-8.259c.438.12.54.662.219.984z" />
  )}
  {name === 'flame' && (
    <path d="M12 3q1 4 4 6.5t3 5.5a1 1 0 0 1-14 0a5 5 0 0 1 1-3a1 1 0 0 0 5 0c0-2-1.5-3-1.5-5q0-2 2.5-4" />
  )}
  {name === 'shower' && (
    <path d="m4 4l2.5 2.5m7 0a4.95 4.95 0 0 0-7 7M15 5L5 15m9 2v.01M10 16v.01M13 13v.01M16 10v.01M11 20v.01M17 14v.01M20 11v.01" />
  )}
  {name === 'settings' && (
    <>
      <path d="M14 17H5M19 7h-9" />
      <circle cx="17" cy="17" r="3" />
      <circle cx="7" cy="7" r="3" />
    </>
  )}
  {name === 'bath' && (
    <path d="M10 4L8 6m9 13v2M2 12h20M7 19v2M9 5L7.621 3.621A2.121 2.121 0 0 0 4 5v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5" />
  )}
  {(name === 'pipe' || name === 'search') && (
    <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.106-3.105c.32-.322.863-.22.983.218a6 6 0 0 1-8.259 7.057l-7.91 7.91a1 1 0 0 1-2.999-3l7.91-7.91a6 6 0 0 1 7.057-8.259c.438.12.54.662.219.984z" />
  )}
  {(name === 'gear') && (
    <>
      <path d="M14 17H5M19 7h-9" />
      <circle cx="17" cy="17" r="3" />
      <circle cx="7" cy="7" r="3" />
    </>
  )}
  {/* Alerte / urgence — utilisée par l'icône "bell" de dépannage. */}
  {name === 'bell' && (
    <path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5S5 13 5 15a7 7 0 0 0 7 7" />
  )}

  {/* ─── Contact ─────────────────────────────────────────────── */}
  {name === 'phone' && (
    <path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233a14 14 0 0 0 6.392 6.384" />
  )}
  {name === 'mail' && (
    <>
      <path d="m22 7l-8.991 5.727a2 2 0 0 1-2.009 0L2 7" />
      <rect width="20" height="16" x="2" y="4" rx="2" />
    </>
  )}
  {name === 'send' && (
    <>
      <path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z" />
      <path d="m21.854 2.147l-10.94 10.939" />
    </>
  )}

  {/* ─── Géographie / temps ──────────────────────────────────── */}
  {name === 'map-pin' && (
    <>
      <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" />
      <circle cx="12" cy="10" r="3" />
    </>
  )}
  {name === 'clock' && (
    <>
      <circle cx="12" cy="12" r="10" />
      <path d="M12 6v6l4 2" />
    </>
  )}

  {/* ─── Confiance / réassurance ─────────────────────────────── */}
  {name === 'shield' && (
    <>
      <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" />
      <path d="m9 12l2 2l4-4" />
    </>
  )}
  {name === 'doc' && (
    <>
      <path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z" />
      <path d="M14 2v5a1 1 0 0 0 1 1h5M10 9H8m8 4H8m8 4H8" />
    </>
  )}
  {name === 'award' && (
    <>
      <path d="m15.477 12.89l1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526" />
      <circle cx="12" cy="8" r="6" />
    </>
  )}
  {name === 'euro' && (
    <path d="M4 10h12M4 14h9m6-8a7.7 7.7 0 0 0-5.2-2A7.9 7.9 0 0 0 6 12c0 4.4 3.5 8 7.8 8c2 0 3.8-.8 5.2-2" />
  )}
  {name === 'star' && (
    <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.12 2.12 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.12 2.12 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.12 2.12 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.12 2.12 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.12 2.12 0 0 0 1.597-1.16z" fill={color} stroke="none" />
  )}
  {name === 'user' && (
    <>
      <circle cx="12" cy="8" r="3.5" />
      <path d="M5 20a7 7 0 0 1 14 0" />
    </>
  )}
  {name === 'calendar' && (
    <>
      <rect x="3.5" y="5" width="17" height="15.5" rx="2" />
      <path d="M8 3v4M16 3v4M3.5 10H20.5" />
    </>
  )}

  {/* ─── Navigation / contrôles ──────────────────────────────── */}
  {name === 'check' && <path d="M20 6L9 17l-5-5" />}
  {name === 'arrow-right' && <path d="M5 12h14m-7-7l7 7l-7 7" />}
  {name === 'chevron-right' && <path d="m9 18l6-6l-6-6" />}
  {name === 'chevron-down' && <path d="m6 9l6 6l6-6" />}
  {name === 'menu' && <path d="M4 5h16M4 12h16M4 19h16" />}
  {name === 'home' && (
    <>
      <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8" />
      <path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
    </>
  )}
  {name === 'image' && (
    <>
      <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
      <circle cx="9" cy="9" r="2" />
      <path d="m21 15l-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
    </>
  )}

  {/* ─── Sociaux ─────────────────────────────────────────────── */}
  {name === 'facebook' && (
    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
  )}
  {name === 'instagram' && (
    <>
      <rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
      <path d="M16 11.37A4 4 0 1 1 12.63 8A4 4 0 0 1 16 11.37m1.5-4.87h.01" />
    </>
  )}
  {name === 'google' && (
    <>
      <circle cx="12" cy="12" r="10" />
      <path d="M12 2a14.5 14.5 0 0 0 0 20a14.5 14.5 0 0 0 0-20M2 12h20" />
    </>
  )}

  {/* ─── Fallback ────────────────────────────────────────────── */}
  {![
    'droplet','droplets','wrench','flame','shower','settings','bath','pipe','search','gear','bell',
    'phone','mail','send',
    'map-pin','clock',
    'shield','doc','award','euro','star','user','calendar',
    'check','arrow-right','chevron-right','chevron-down','menu','home','image',
    'facebook','instagram','google',
    /* alias rétro-compatibles phase 1 */
    'alert','tap','drain',
  ].includes(name) && (
    <text x="12" y="16" text-anchor="middle" font-size="14" fill={color} stroke="none">?</text>
  )}

  {/* Alias rétro-compatibles avec la phase 1. */}
  {name === 'alert' && (
    <path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5S5 13 5 15a7 7 0 0 0 7 7" />
  )}
  {name === 'tap' && (
    <>
      <path d="M14 17H5M19 7h-9" />
      <circle cx="17" cy="17" r="3" />
      <circle cx="7" cy="7" r="3" />
    </>
  )}
  {name === 'drain' && (
    <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.106-3.105c.32-.322.863-.22.983.218a6 6 0 0 1-8.259 7.057l-7.91 7.91a1 1 0 0 1-2.999-3l7.91-7.91a6 6 0 0 1 7.057-8.259c.438.12.54.662.219.984z" />
  )}
</svg>

<style>
  .icon {
    flex-shrink: 0;
    display: inline-block;
    vertical-align: middle;
  }
</style>
