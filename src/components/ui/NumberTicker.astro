---
/**
 * NumberTicker.astro — Primitive UI.
 *
 * Rôle : compteur animé qui démarre quand l'élément entre dans le
 * viewport (IntersectionObserver). Inspiré du Number Ticker de Magic UI
 * et du Counter de 21st.dev, adapté en Astro pur (zéro dépendance).
 *
 * Usage :
 *   <NumberTicker value={5} decimals={1} />            → "5,0"
 *   <NumberTicker value={13} prefix="" suffix=" avis" />
 *   <NumberTicker value={1} prefix="< " suffix=" h" />
 *
 * L'animation respecte `prefers-reduced-motion` (affichage instantané
 * de la valeur cible).
 */

export interface Props {
  /** Valeur cible. */
  value: number;
  /** Valeur de départ (par défaut 0). */
  startValue?: number;
  /** Nombre de décimales. */
  decimals?: number;
  /** Durée de l'animation en ms (par défaut 1400). */
  duration?: number;
  /** Délai avant démarrage en ms. */
  delay?: number;
  /** Texte avant le nombre (ex. "< "). */
  prefix?: string;
  /** Texte après le nombre (ex. " avis"). */
  suffix?: string;
  /** Séparateur décimal (fr-FR par défaut : virgule). */
  decimalSeparator?: string;
  class?: string;
}

const {
  value,
  startValue = 0,
  decimals = 0,
  duration = 1400,
  delay = 0,
  prefix = '',
  suffix = '',
  decimalSeparator = ',',
  class: className,
} = Astro.props;

const classes = ['number-ticker', className].filter(Boolean).join(' ');

/* Affichage initial (sans JS) = startValue formatté. Si JS exécute,
   IntersectionObserver lance l'animation. */
const initialDisplay = startValue
  .toFixed(decimals)
  .replace('.', decimalSeparator);
---

<span
  class={classes}
  data-target={value}
  data-start={startValue}
  data-decimals={decimals}
  data-duration={duration}
  data-delay={delay}
  data-sep={decimalSeparator}
  data-prefix={prefix}
  data-suffix={suffix}
>{prefix}{initialDisplay}{suffix}</span>

<script is:inline>
  (() => {
    /* Initialisation une seule fois par script (idempotent même sur
       re-hydration partielle). */
    if (window.__yppNumberTickerInit) return;
    window.__yppNumberTickerInit = true;

    const reduceMotion =
      window.matchMedia &&
      window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function formatValue(value, decimals, sep) {
      const fixed = value.toFixed(decimals);
      return decimals > 0 ? fixed.replace('.', sep) : fixed;
    }

    function easeOutCubic(t) {
      return 1 - Math.pow(1 - t, 3);
    }

    function animateTo(el) {
      const target = parseFloat(el.dataset.target);
      const start = parseFloat(el.dataset.start ?? '0');
      const decimals = parseInt(el.dataset.decimals ?? '0', 10);
      const duration = parseInt(el.dataset.duration ?? '1400', 10);
      const delay = parseInt(el.dataset.delay ?? '0', 10);
      const sep = el.dataset.sep ?? ',';
      const prefix = el.dataset.prefix ?? '';
      const suffix = el.dataset.suffix ?? '';

      if (reduceMotion) {
        el.textContent = prefix + formatValue(target, decimals, sep) + suffix;
        return;
      }

      const run = () => {
        const t0 = performance.now();
        const tick = (now) => {
          const elapsed = now - t0;
          const progress = Math.min(elapsed / duration, 1);
          const eased = easeOutCubic(progress);
          const current = start + (target - start) * eased;
          el.textContent =
            prefix + formatValue(current, decimals, sep) + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };
      if (delay > 0) setTimeout(run, delay);
      else run();
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            animateTo(entry.target);
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.4, rootMargin: '0px 0px -40px 0px' },
    );

    function bind() {
      document
        .querySelectorAll('.number-ticker:not([data-bound])')
        .forEach((el) => {
          el.setAttribute('data-bound', '1');
          observer.observe(el);
        });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bind);
    } else {
      bind();
    }

    // Pour les chargements partiels (View Transitions Astro).
    document.addEventListener('astro:page-load', bind);
  })();
</script>

<style>
  .number-ticker {
    display: inline-block;
    font-variant-numeric: tabular-nums;
  }
</style>
