---
/**
 * ReviewCard.astro — Primitive UI.
 *
 * Rôle : afficher un avis client. Identité « Baie des Anges » :
 *   - guillemet d'ouverture Playfair en grand, accent laiton (anti-AI-slop) ;
 *   - citation en Playfair 19 px, weight 500 ;
 *   - en pied : nom + lieu à gauche, étoiles ocre à droite (séparés
 *     par une hairline).
 *
 * Rendu dans : ReviewsSection.
 */

import Icon from './Icon.astro';

export interface Props {
  rating: number;
  quote: string;
  author: string;
  /** Localité (ex. « Nice — Cimiez »). */
  place?: string;
  /** Source (rare — par défaut implicite via la page). */
  source?: string;
}

const { rating, quote, author, place } = Astro.props;
const stars = Math.max(0, Math.min(5, Math.round(rating)));
---

<figure class="review-card">
  <span class="review-card__mark" aria-hidden="true">&ldquo;</span>
  <blockquote class="review-card__quote">
    <p>{quote}</p>
  </blockquote>
  <figcaption class="review-card__foot">
    <div>
      <p class="review-card__author">{author}</p>
      {place && <p class="review-card__place">{place}</p>}
    </div>
    <span class="stars" aria-label={`Note : ${stars} sur 5`}>
      {Array.from({ length: stars }).map(() => (
        <Icon name="star" size={16} />
      ))}
    </span>
  </figcaption>
</figure>

<style>
  .review-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-8);
    margin: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    height: 100%;
  }
  .review-card__mark {
    font-family: var(--font-family-heading);
    font-size: 64px;
    line-height: 0.6;
    color: var(--color-laiton);
    height: 28px;
    opacity: 0.7;
  }
  .review-card__quote {
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-family-heading);
    font-weight: var(--font-weight-medium);
    font-size: 1.1875rem; /* 19px */
    line-height: 1.5;
    flex: 1;
  }
  .review-card__quote p { margin: 0; }
  .review-card__foot {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border-soft);
  }
  .review-card__author {
    margin: 0;
    font-weight: var(--font-weight-semibold);
    font-size: 0.9rem;
    color: var(--color-text);
  }
  .review-card__place {
    margin: 2px 0 0 0;
    font-size: 0.78rem; /* 12.5px */
    color: var(--color-text-muted);
  }
</style>
