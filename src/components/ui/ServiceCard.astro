---
/**
 * ServiceCard.astro — Primitive UI.
 *
 * Direction "Éditorial Architecture" :
 *   - Carte rectangulaire sans rayon, fond surface, fine ligne haut.
 *   - Numéro chapitre mono géant ("01", "02"…) en haut.
 *   - Titre Fraunces, description Inter, lien flèche en bas.
 *   - Hover : la carte vire en charbon, le numéro en terracotta.
 *
 * Rendu dans : ServicesGrid, ServiceCrossLinks.
 */

export interface Props {
  href: string;
  title: string;
  description: string;
  icon: string;
  number?: string;
  headingLevel?: 2 | 3 | 4;
}

const { href, title, description, number, headingLevel = 3 } = Astro.props;
const Heading = `h${headingLevel}` as 'h2' | 'h3' | 'h4';
---

<article class="service-card">
  {number && (
    <span class="service-card__number" aria-hidden="true">{number}</span>
  )}
  <Heading class="service-card__title">
    <a class="service-card__link" href={href}>
      <span>{title}</span>
      <span class="visually-hidden"> : en savoir plus</span>
    </a>
  </Heading>
  <p class="service-card__description">{description}</p>
  <span class="service-card__cta" aria-hidden="true">
    <span>Voir le service</span>
    <span class="service-card__arrow">→</span>
  </span>
</article>

<style>
  .service-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: clamp(2rem, 3vw, 2.75rem) clamp(1.5rem, 2.5vw, 2.5rem) clamp(1.75rem, 2.5vw, 2.25rem);
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    height: 100%;
    transition:
      background-color var(--transition-base) var(--ease-out),
      color var(--transition-base) var(--ease-out);
  }
  .service-card:hover {
    background-color: var(--color-text);
    color: var(--color-on-dark);
  }
  .service-card:hover .service-card__number {
    color: var(--color-terra);
  }
  .service-card:hover .service-card__title,
  .service-card:hover .service-card__description,
  .service-card:hover .service-card__cta {
    color: var(--color-on-dark);
  }
  .service-card:hover .service-card__arrow {
    transform: translateX(6px);
    color: var(--color-terra);
  }

  .service-card__number {
    font-family: var(--font-family-mono);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-soft);
    transition: color var(--transition-base) var(--ease-out);
  }

  .service-card__title {
    margin: 0;
    font-family: var(--font-family-display);
    font-weight: var(--font-weight-medium);
    font-size: clamp(1.5rem, 2.2vw, 1.875rem);
    line-height: 1.05;
    letter-spacing: var(--letter-spacing-tight);
    color: var(--color-text);
    transition: color var(--transition-base) var(--ease-out);
  }
  .service-card__link {
    color: inherit;
    text-decoration: none;
  }
  .service-card__link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .service-card__description {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
    flex: 1;
    transition: color var(--transition-base) var(--ease-out);
  }

  .service-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-5);
    margin-top: var(--space-1);
    border-top: 1px solid var(--color-border-soft);
    font-family: var(--font-family-mono);
    font-size: 0.7rem;
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text);
    transition: color var(--transition-base) var(--ease-out);
  }
  .service-card__arrow {
    display: inline-block;
    transition: transform var(--transition-base) var(--ease-out), color var(--transition-base) var(--ease-out);
  }
</style>
