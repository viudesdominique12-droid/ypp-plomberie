---
/**
 * Stepper.astro — Primitive UI.
 *
 * Rôle : process en N étapes. Chaque étape = carte avec cercle
 * numéroté azur + filet de laiton, H4 Playfair, description.
 *
 * Rendu dans : ProcessSteps (accueil), ServiceProcessSection.
 */

import AnimatedBeam from './AnimatedBeam.astro';

export interface Step {
  title: string;
  description: string;
}

export interface Props {
  steps: Step[];
  headingLevel?: 3 | 4;
  /** Nombre de colonnes desktop (par défaut 4 — peut être ajusté à 3). */
  columns?: 3 | 4;
}

const { steps, headingLevel = 3, columns = 4 } = Astro.props;
const Heading = `h${headingLevel}` as 'h3' | 'h4';
---

<div class="stepper-wrap">
  {/* Beam d'eau qui coule horizontalement à travers la rangée
       de cartes — visible uniquement en desktop. */}
  <AnimatedBeam
    class="stepper__beam"
    baseColor="rgba(14, 100, 128, 0.18)"
    pulseColor="rgba(14, 100, 128, 0.9)"
    duration={5}
    thickness={2}
  />
  <ol class={`stepper stepper--cols-${columns}`} role="list">
    {steps.map((step, index) => (
      <li class="stepper__item">
        <div class="stepper__head">
          <span class="stepper__number" aria-hidden="true">{index + 1}</span>
          <span class="stepper__brass" aria-hidden="true"></span>
        </div>
        <Heading class="stepper__title">{step.title}</Heading>
        <p class="stepper__description">{step.description}</p>
      </li>
    ))}
  </ol>
</div>

<style>
  .stepper-wrap {
    position: relative;
  }
  /* Beam d'eau visible uniquement en desktop, derrière les chiffres. */
  .stepper-wrap :global(.stepper__beam) {
    display: none;
  }
  @media (min-width: 1024px) {
    .stepper-wrap :global(.stepper__beam) {
      display: block;
      position: absolute;
      top: 47px; /* hauteur d'un chiffre + offset ; aligne sur centre rond */
      left: 8%;
      right: 8%;
      width: 84%;
      z-index: 0;
    }
  }
  .stepper {
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
    position: relative;
    z-index: 1;
  }
  @media (min-width: 768px) {
    .stepper {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-5);
    }
  }
  @media (min-width: 1024px) {
    .stepper--cols-3 { grid-template-columns: repeat(3, 1fr); }
    .stepper--cols-4 { grid-template-columns: repeat(4, 1fr); }
  }

  .stepper__item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    transition:
      border-color var(--transition-fast) var(--ease-out),
      box-shadow var(--transition-fast) var(--ease-out);
  }
  .stepper__item:hover {
    border-color: var(--color-azur);
    box-shadow: var(--shadow-sm);
  }
  .stepper__head {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
  }
  /* Halo « onde » autour du chiffre quand on survole la carte —
     1 anneau azur-light qui apparaît et disparaît en douceur. */
  .stepper__number {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    background: var(--color-azur);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-family-heading);
    font-weight: var(--font-weight-semibold);
    font-size: 1.1875rem; /* 19px — Playfair sub-min OK ici (chiffre, pas du texte) */
    position: relative;
  }
  .stepper__number::before {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: var(--radius-full);
    border: 1.5px solid var(--color-azur-light);
    opacity: 0;
    transition: opacity var(--transition-base) var(--ease-out),
                inset var(--transition-base) var(--ease-out);
  }
  .stepper__item:hover .stepper__number::before {
    opacity: 1;
    inset: -10px;
  }
  .stepper__brass {
    flex: 1;
    height: 1.5px;
    background: var(--color-laiton);
    opacity: 0.9;
  }
  .stepper__title {
    margin: 0 0 var(--space-2) 0;
    font-size: var(--font-size-lg);
    line-height: 1.3;
    color: var(--color-text);
  }
  .stepper__description {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.65;
  }
</style>
