---
/**
 * WaterDropLogo.astro — Primitive UI.
 *
 * Rôle : monogramme logo « goutte d'eau ». Forme géométrique propre,
 * filet intérieur qui suggère un reflet d'eau. À utiliser dans le
 * Header et le Footer.
 *
 * Au hover, la goutte « pulse » très légèrement (battement subtil,
 * une itération via group hover, prefers-reduced-motion respecté).
 *
 * Pas une animation décorative permanente — c'est une transition
 * d'état (group hover du parent .site-header__brand), conforme au
 * spec « transitions d'état uniquement ».
 */

export interface Props {
  size?: number;
  /** Variante : "azur" (par défaut, header) ou "light" (footer dark). */
  variant?: 'azur' | 'light';
  class?: string;
}

const { size = 36, variant = 'azur', class: className } = Astro.props;
const classes = ['water-drop-logo', `water-drop-logo--${variant}`, className]
  .filter(Boolean)
  .join(' ');
---

<span class={classes} style={`width: ${size}px; height: ${size}px;`} aria-hidden="true">
  <svg
    width="100%"
    height="100%"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    {/* La goutte. */}
    <path
      class="water-drop-logo__drop"
      d="M12 3s7 7 7 12a7 7 0 1 1-14 0c0-5 7-12 7-12z"
    />
    {/* Reflet intérieur : suggère la surface de l'eau qui tremble. */}
    <path
      class="water-drop-logo__highlight"
      d="M9 14.5c0 1.4 1 2.5 2.4 2.5"
      opacity="0.6"
    />
  </svg>
</span>

<style>
  .water-drop-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    flex-shrink: 0;
    transition: background-color var(--transition-fast) var(--ease-out);
  }
  .water-drop-logo--azur {
    background: var(--color-azur);
    color: #fff;
  }
  .water-drop-logo--light {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.18);
  }

  /* Au hover du parent (brand), pulsation subtile UNE fois. */
  :global(.site-header__brand:hover) .water-drop-logo__drop,
  :global(.site-footer__brand:hover) .water-drop-logo__drop {
    animation: ypp-drop-pulse 0.45s var(--ease-out);
    transform-origin: 12px 14px;
  }
  :global(.site-header__brand:hover) .water-drop-logo,
  :global(.site-footer__brand:hover) .water-drop-logo--azur {
    background: var(--color-azur-hover);
  }
</style>
