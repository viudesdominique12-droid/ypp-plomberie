---
/**
 * Wave.astro — Primitive UI.
 *
 * Rôle : séparateur SVG en forme de vague — pour souligner le thème
 * « eau qui coule » sans tomber dans l'AI-slop. C'est un trait
 * de couture, pas une décoration. Couleur azur-light très diluée.
 *
 * Le SVG est PUREMENT STATIQUE (pas d'animation). Il pose un rythme
 * géométrique calme entre deux sections — comme un filet de laiton
 * mais en version « eau ».
 *
 * Usage :
 *   <Wave color="azur-light" />   {/* défaut, fond surface *\/}
 *   <Wave color="surface-alt" />  {/* sur fond bg ou azur clair *\/}
 *
 * Rendu dans : entre certaines sections (hero → trustbar,
 *              avis → zones, etc.).
 */

export interface Props {
  /** Couleur de remplissage de la vague. */
  color?: 'azur-light' | 'surface-alt' | 'border-soft';
  /** Inverser la vague verticalement (utile en bordure haute / basse). */
  flip?: boolean;
  /** Hauteur en pixels — par défaut 56. */
  height?: number;
  class?: string;
}

const {
  color = 'azur-light',
  flip = false,
  height = 56,
  class: className,
} = Astro.props;

const colorVar = {
  'azur-light': 'var(--color-azur-light)',
  'surface-alt': 'var(--color-surface-alt)',
  'border-soft': 'var(--color-border-soft)',
}[color];

const classes = ['wave', flip ? 'wave--flip' : null, className]
  .filter(Boolean)
  .join(' ');
---

<div class={classes} style={`height: ${height}px;`} aria-hidden="true">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 1200 56"
    preserveAspectRatio="none"
    width="100%"
    height="100%"
  >
    {/* Trois ondulations légères, signature courbe douce ~SinX. */}
    <path
      d="M0 36 C 150 6, 350 56, 600 28 S 1050 0, 1200 36 L 1200 56 L 0 56 Z"
      fill={colorVar}
    />
  </svg>
</div>

<style>
  .wave {
    display: block;
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }
  .wave svg { display: block; width: 100%; height: 100%; }
  .wave--flip svg { transform: scaleY(-1); }
</style>
